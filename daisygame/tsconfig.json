{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["ES2020", "DOM"],
    "outDir": "./js",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "noFallthroughCasesInSwitch": true,
    "removeComments": false,
    "newLine": "lf",
    "isolatedModules": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
